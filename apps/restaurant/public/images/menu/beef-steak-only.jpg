							node_ids: [0, 3, 21],
							data: [{type:"data",data:{theme:"auto",excludeSeoData:false,is_crawler:false,version:{commit:{sha:"57d01227c37770ea3f6546b610a660038cfc4402",date:1778501848000,refs:["HEAD",["t","v2.20.2"],["b","master"]]},build:{number:"174",date:1778502065000,triggerName:"v2.20.2",triggerType:"tag"},apiVersionHeader:"v2.20.2"},useLegacyTermsPage:false},uses:{}},{type:"data",data:{inserts:[]},uses:{}},{type:"data",data:{excludeSeoData:false,canonical:"https://www.mrd.com/delivery/restaurants",meta:[{title:"Food Delivery & Grocery Delivery | Order Online w/ MRD.com"},{name:"twitter:title",content:"Food Delivery & Grocery Delivery | Order Online w/ MRD.com"},{property:"og:title",content:"Food Delivery & Grocery Delivery | Order Online w/ MRD.com"},{name:"description",content:"Download the Mr D app to enjoy convenient grocery and food delivery from over 11,000 restaurants and stores, and 300+ Pick n Pay grocery stores. Pay with cash, card, or EFT and get your order delivered to over 2,600 suburbs across South Africa. Satisfy your cravings with ease!"},{name:"twitter:description",content:"Download the Mr D app to enjoy convenient grocery and food delivery from over 11,000 restaurants and stores, and 300+ Pick n Pay grocery stores. Pay with cash, card, or EFT and get your order delivered to over 2,600 suburbs across South Africa. Satisfy your cravings with ease!"},{property:"og:description",content:"Download the Mr D app to enjoy convenient grocery and food delivery from over 11,000 restaurants and stores, and 300+ Pick n Pay grocery stores. Pay with cash, card, or EFT and get your order delivered to over 2,600 suburbs across South Africa. Satisfy your cravings with ease!"},{name:"twitter:image",content:"https://img.mrdfood.com/506x253/seo/f614d870-0589-4d53-8366-59161bc5df17.png"},{property:"og:image",content:"https://img.mrdfood.com/1200x628/seo/f614d870-0589-4d53-8366-59161bc5df17.png"},{property:"og:image:width",content:"1200"},{property:"og:image:height",content:"628"},{property:"og:type",content:"website"},{property:"og:url",content:"https://www.mrd.com"}],pages:[{readme:"Web V2 CMS",id:"__readme"},{description:"WebV2 CMS",id:"_readme"},{description:"Long yummy piece about burgers.",slug:"burgers",id:"burgers"},{"block-4-title":"Save your favourite items to your home screen. ",description:"Groceries delivered in 60 minutes at in store prices. With over 300 Pick n Pay stores available.","block-6-title":"Place an order for tomorrow. ",title:"Shop the world of Pick n Pay on Mr D","block-2-img":"web-v2/efb45b0c-22d2-4fd3-a4ee-0813d61efade.png","block-2-title":"Earn Smart Shopper points. ","block-0-title":"Save with combos and deals. ","block-0-description":"Shop over 27,000  products at in-store prices and save with exclusive app only deals.","block-3-img":"web-v2/3d6de4f9-0921-4f66-b1c3-100be6df80c5.png",slug:"home-grocery","block-0-img":"web-v2/2244e8b7-dfc3-4735-9882-6882d30445c2.png","block-5-title":"Re-order items from previous orders. ","block-5-img":"web-v2/f10867ec-dc4d-4086-b665-f6d6ab53f79d.png","block-1-description":"Locally sourced fruits and vegetables delivered fast and fresh.\u2028","block-4-img":"web-v2/8bc24cf8-6b9f-4392-8084-b44a14aa0401.png","block-3-title":"Select a backup in case it’s sold out. ","block-2-description":"Link your Smart Shopper card to earn points every time you shop.","block-4-description":"Right click to add any item to your landing page.","block-6-img":"web-v2/998d2195-abdd-46c6-9694-1fff25eaa4d7.png","block-1-img":"web-v2/0246cab7-9978-4a33-b143-3e8866230b96.png","block-5-description":"No need to search for your favourites. ","block-3-description":"We’ll apply these backups to your next order.","block-1-title":"As fresh as if you picked it yourself. ","address-prompt":"Start shopping now","block-6-description":"Shopping late? Place an order to be delivered early the next day.",image:"web-v2/4095619f-037b-4713-b776-bc76d20d5ea6.jpg","block-7-description":"Plus, get access to exclusive deals, from just R39 per month.","block-7-title":"Get free delivery on your grocery orders! ","block-7-img":"web-v2/3326e2d7-9e0e-4932-abcf-8ba59d1862fe.png",id:"home-grocery"},{image:"web-v2/f9330441-5db4-4517-a30c-cc88047c3576.jpg","block-0-img":"web-v2/04f7db72-2d46-4796-ade1-15d9e701037e.png","block-4-title":"Track your driver in real time. ",description:"Get daily delicious deals and R50 OFF your first order from over 12 000 restaurants, all delivered in 60 minutes.","block-4-img":"web-v2/59ded16c-f70c-4b0d-9ae4-f6498d1e3939.png","block-1-description":"From burgers, chicken, pizza, asian, Indian food and more.","block-3-title":"Pay with card, cash, eBucks or EFT. ","block-2-description":"Save with daily promotions and discounts on your favourite restaurants.",title:"Order food from your favourite restaurants","block-2-img":"web-v2/4be96ae7-74af-4fb2-8497-a2184f05633b.png","block-4-description":"Still can't find your driver? Message them directly on Mr D.","block-1-img":"web-v2/1760b812-c4f5-4ff1-a277-e226639a848d.png","block-2-title":"Hungry for a deal? ","block-3-description":"We accept a variety of payment methods for your convenience.","block-1-title":"Try something new and tasty.","block-0-title":"Order takeout from your favourite brands. ","block-0-description":"Get it delivered fast and hot.","address-prompt":"Start browsing restaurants now","block-3-img":"web-v2/e196727d-24b9-4b4e-915c-06126b072e94.png",slug:"home-restaurant",id:"home-restaurant"},{"block-4-title":"Shop flowers. ","block-7-img":"web-v2/dce7d7bf-056e-4361-97e8-57a64d1eda09.png","block-6-title":"Health essentials delivered. ",description:"Explore our range of stores from gifting to liquor. Delivered to you in a flash.",title:"Order from your favourite shops","block-2-img":"web-v2/74ca0736-2e45-4c23-b364-4ce116aa8c54.png","block-2-title":"Shop pet care, pet food and accessories. ",address_prompt:"Hi","block-8-img":"web-v2/4d6794f2-fae1-41e6-badd-e23af281e358.png","block-8-title":"Track your driver in real time. ","block-0-description":"The best of Takealot. Delivered to you in an hour. ","block-0-title":"TakealotNow: ","block-3-img":"web-v2/cd24dcf3-8fce-45b7-a411-4c28c6a90f13.png",slug:"home-store",image:"web-v2/324dcc46-a132-4992-b18d-7c5fc89a8a53.jpg","block-0-img":"web-v2/8a6b74df-b52a-4676-b833-28d37ebf9f91.png","block-5-title":"Shop Beauty. ","block-5-img":"web-v2/88ae0596-93c3-42a0-ae9c-81168f0e6fc4.png","block-4-img":"web-v2/f9704902-20f5-4609-8f44-b0928b17264c.png","block-1-description":"No more last minute grocery runs. Get your essentials delivered in minutes","block-3-title":"Liquor delivered to your door. ","block-2-description":"Everything your pet needs, delivered in minutes.","block-7-title":"Shop Gifting. ","block-6-img":"web-v2/c66c2eb9-0813-4487-a111-3c3eb4f29ea1.png","block-4-description":"Fresh blooms, delivered to you or your loved ones with a tap","block-1-img":"web-v2/c175852f-7005-44b1-8921-9d8c8e4cc520.png","block-3-description":"All your favourites, delivered to you cold and fast.","block-5-description":"Get it all from fragrances to skincare, delivered to your door.","block-1-title":"Convenience Stores. ","block-8-description":"Still can't find your driver? Message them directly on Mr D.","address-prompt":"Order from your favourite shops today\n","block-7-description":"Effortless gifting for the \"Thank You\" & \"I'm sorry\" moments.","block-6-description":"Get all you need to beat the flu and more, straight to your door.","block-9-description":"Plus, get access to exclusive deals, from just R39 per month.","block-9-title":"Get free delivery on your shops orders!","block-9-img":"web-v2/3326e2d7-9e0e-4932-abcf-8ba59d1862fe.png",id:"home-store"}],brands:[{slug:"hello-tomato",name:"Hello Tomato",adminId:"172",vertical:"restaurant",description:"Hello Tomato, Mr D has the menu for you. Download the app and get incredible pizzas and pastas with the freshest ingredients.\n",banner:"seo/9c3e5428-bb5b-412c-ab23-ce15176246fb.jpg",logo:"seo/085474d6-e775-4a81-baf3-a486db3ee435.jpg",isRetail:void 0},{slug:"bento",name:"Bento",adminId:"1136",vertical:"restaurant",description:"Get the burger of your dreams from the newest burger joint on the block, Bento. It is home to a wide range of unbelievably good burgers and the tastiest sides. Download the Mr D app to get Bento delivered fast and hot",banner:"seo/d24cabae-9277-459f-9f88-dda5b150b09a.jpg",logo:"seo/8f6bea7c-9282-49dd-88fd-054f70f2a925.jpg",isRetail:void 0},{slug:"afrikoa",name:"Afrikoa",adminId:null,vertical:"restaurant",description:"Afrikoa are proud to be the only chocolate producer in Africa that uses purely heirloom cacao beans. Ancient heirloom cacao beans, also known as the 'diamonds",banner:"seo/cf8ad75b-fc16-48aa-b7fa-2e739332da57.jpg",logo:"seo/a975e660-7d81-452e-8b69-bb9c9a3928ae.jpg",isRetail:void 0},{slug:"cinnabon",name:"Cinnabon",adminId:1016,vertical:"restaurant",description:"Got a bit of a sweet tooth? Get all your favourite Cinnabon treats and beverages delivered!\n An irresistible experience is simply, one tap away.",banner:"web-v2/9ef3e078-9a64-46ea-9497-accbdfe626a6.jpeg",logo:"web-v2/1e286767-c2f4-423d-8820-3add2ae010fa.jpeg",isRetail:void 0},{slug:"mimmos",name:"Mimmos",adminId:"26",vertical:"restaurant",description:"Everything at Mimmos is made with love. Download the app, order your favourite food from Mimmos to get the joy of food, delivered",banner:"seo/2edeb9ae-b8a2-4332-afc6-3564e9b9ea1f.jpg",logo:"seo/e79c1016-6ff7-48da-a2ca-06321c3182af.jpg",isRetail:void 0},{slug:"wellness-warehouse",name:"Wellness Warehouse",adminId:"1963",vertical:"store",description:"Wellness Warehouse is now available on Mr D. As SA's leading wellness store. Shop supplements, beauty, food & more. Wellness Warehouse is for the body, mind & home.",banner:"web-v2/4f5829ac-dbc9-4b62-94c8-4bc5d1d45989.png",logo:"web-v2/888a2a04-05cc-4e80-ac06-d5da011f62a9.png",isRetail:true},{slug:"romans-pizza",name:"Roman's Pizza",adminId:"182",vertical:"restaurant",description:"Roman's Pizza is famous all over SA and we deliver all over SA. Coincidence? We think not. Enjoy all your favourites from Romans including their famous specials delivered at the tap of our app. ",banner:"web-v2/32c2b2dd-7b4a-457e-934a-3fe65542fdb8.png",logo:"web-v2/57e9e6df-60c7-49cb-94ca-a6aa2596c5e0.png",isRetail:true},{slug:"nna-stationers",name:"NNA Stationers",adminId:"1807",vertical:"store",description:"Discover NNA Stationers, the leading online stationery store in South Africa. Offering a wide range of office supplies for both personal and professional use. Whether you're working from home or in an office, we've got you covered. Partner with us for opportunities in Durban, Soweto, Midrand, Port Elizabeth, Nelspruit, Bloemfontein, and more. Open daily from 07:00 - 22:00. Now available for delivery on Mr D.",banner:"seo/fcefc2fb-93d0-4b8e-a2a7-e60f18687761.jpg",logo:"seo/e1277e48-fb78-4115-843b-4fef12933870.jpg",isRetail:void 0},{slug:"blom-flower-and-gift-bar",name:"Blom Flower and Gift Bar ",adminId:null,vertical:"store",description:"We create a service where personalised gifting and intimate private events can be personalised and celebrated with ease.",banner:"seo/13283f10-f36f-4bda-8643-ab7d5924836c.jpg",logo:"seo/5e70cd88-3a78-4053-a3c2-fcae4cdd7ef3.jpg",isRetail:void 0},{slug:"personalised4u",name:"Personalised4U",adminId:void 0,vertical:"store",description:"Personalised gifts, clothing and much more available online and in-store.\nDesign your own personalised custom t-shirts, caps & clothing, mugs, lunch boxes, drinks bottles, and more ONLINE!",banner:"seo/9d6f9536-cc5b-4540-a889-333acbbb8cdf.jpg",logo:"seo/ea58e7c5-3244-464f-9341-c2e8e54bec03.jpg",isRetail:void 0},{slug:"pizza-hut",name:"Pizza Hut",adminId:"46",vertical:"restaurant",description:"\nIf you're looking for a classic, look no further than Pizza Hut. Find Pizza Hut",banner:"seo/1acefdd2-8c50-460e-82ab-bb7e89258df5.jpg",logo:"seo/9337d80e-96e3-48b6-ad48-83b8fbb04a0d.png",isRetail:void 0},{slug:"petworld",name:"Petworld",adminId:1680,vertical:"store",description:null,banner:"web-v2/c618801c-dab9-4f70-ac0a-105a7733ddd7.png",logo:"web-v2/fa508849-b23c-4df4-b2c8-248e3634b9ac.png",isRetail:void 0},{slug:"burger-king",name:"Burger King",adminId:1023,vertical:"restaurant",description:"Enjoy a flame-grilled WHOPPER® or premium value meal with fries and drink wherever you are with BURGER KING. You can have it your way everyday.",banner:"web-v2/f9834232-e3f5-4a23-8964-fa66742ea335.png",logo:"seo/3290adc5-9ebb-4ade-9d02-24288e3eade3.png",isRetail:void 0},{slug:"chilpil",name:"ChilPil",adminId:void 0,vertical:"store",description:"Chilpil chairs are made from ultra durable Polyester 1600D waterproof material with a high quality zipper.",banner:"seo/04ba664e-9209-4299-a21a-a22ff556efa3.jpg",logo:"seo/fdeac794-b859-41c8-8add-95df0a00043c.jpg",isRetail:void 0},{slug:"nu",name:"Nü",adminId:"1015",vertical:"restaurant",description:"Nü Health Food Café serves up garden-fresh food and superior nutrition. Download the app to order fast & hot delivery of the freshest greens, wraps, and smoothies from Nü\n",banner:"seo/676427ad-610f-418e-ac13-93089d581de1.jpg",logo:"seo/97b9bda3-becc-42f1-84d2-bf4a74c39cc3.jpg",isRetail:void 0},{slug:"debonairs-pizza",name:"Debonairs Pizza",adminId:"1006",vertical:"restaurant",description:"Crammed Crusts, Triple Deckers, and that special sauce you know and love. Download the app to get the best delivery of your favourite Debonairs Pizza fast & hot by Mr D.",banner:"web-v2/13cbf49f-98ae-4d54-8f82-e5ae55b8bbc5.png",logo:"web-v2/da10a795-6ac4-4c35-9033-83ec849f303e.png",isRetail:void 0},{slug:"colcacchio-go ",name:"Col’Cacchio GO ",adminId:1904,vertical:"restaurant",description:"Whether you're working from home or juggling a million tabs at the office, our on-the-go lunch deals are here to fuel you right, fresh, fast, and full of flavour.\nBecause even busy days deserve a delicious pause.",banner:"web-v2/9bf64356-30c6-49bb-9efe-99c053c3f908.png",logo:"web-v2/e782ad05-6efd-46f8-a54c-bbfbf5895528.png",isRetail:void 0},{slug:"colcacchio",name:"Col'Cacchio",adminId:"6",vertical:"restaurant",description:"Nothing says 'pizza night' like Col'Cacchio. If there's a Col'Cacchio near you we'll deliver it fast & hot at the tap of an app. Kick back, chill out and chow down. We deliver Col'Cacchio all over SA.  \n",banner:"seo/9fc35bcb-3a0a-44e2-90fa-46b6bec1d254.jpg",logo:"seo/9a4947f2-2f6d-4b94-bf17-b0dbf18d1f09.png",isRetail:void 0},{slug:"blue-bottle-liquors",name:"Blue Bottle Liquors",adminId:1663,vertical:"store",description:" Blue Bottle Liquors is a community of independent liquor store owners who participate jointly and collectively to maximise the buying power to access more competitive deals and good practices of business management. Blue Bottle's range starts anywhere from chilled beers to premium liqueur. Whether you're stocking up for the weekend, have surprise guests or need to top up your liquor - Blue Bottle on Mr D has you covered. ",banner:"web-v2/5636b49e-1e8a-4bae-8da1-de4d933add76.png",logo:"web-v2/9b839d5c-0c75-4725-bd76-20b0d0c83b3d.png",isRetail:void 0},{slug:"mythos",name:"Mythos",adminId:"51",vertical:"restaurant",description:"Opa! Choose Greek at Mythos, the home of authentic Greek cuisine. Expect moussaka, tzatziki, falafel, meze platters, tapas and baklavas. It’s the Greek culinary world splashed onto one menu. Download the Mr D app and get the joy of Greek food delivered.\n",banner:"seo/865eedf9-a86d-4dda-bf65-e600cab0b8d0.jpg",logo:"seo/f2e9471f-ab2c-4ddf-92c1-d4040c478677.jpg",isRetail:void 0},{slug:"the-hussar-grill",name:"The Hussar Grill",adminId:"119",vertical:"restaurant",description:"Hussar Grill is a cut above the rest. The 55 year old restaurant has spent decades perfecting the art of flame grill. Enjoy perfectly aged succulent steaks, ribs that literally fall off the bone and delectable house specialities. Order now to get the joy of Hussar Grill, delivered. \n",banner:"seo/d82db71e-af30-4ee5-b995-7fbdbca5a43d.jpg",logo:"seo/e7c92f5a-d551-4703-bb21-a70e9323f01a.jpg",isRetail:void 0},{slug:"cosy-corner",name:"Cosy Corner",adminId:null,vertical:"restaurant",description:"Enjoy Cosy Corner's legendary menu without leaving the house. Download the app, order your favourite food from Cosy Corner to get the joy of food, delivered",banner:"seo/34ace444-0d1e-4d96-87b9-f04601a56f5f.png",logo:"seo/f1c38f04-7647-4ecd-920c-c5ca53b61c45.png",isRetail:void 0},{slug:"pizza-perfect",name:"Pizza Perfect",adminId:"11",vertical:"restaurant",description:"It's got perfect in the name you know it's gotta be good. Get Pizza Perfect in your area delivered fast & hot. Enjoy their delicious pizzas, subs and more delivered at the tap of an app. Find Pizza Perfect now. ",banner:"seo/8565a675-19c0-45aa-928b-2bba00e96553.jpg",logo:"seo/0f1d82c7-f328-4b72-97ab-612e44db64a4.png",isRetail:void 0},{slug:"honchos",name:"Honchos",adminId:"1032",vertical:"restaurant",description:"Order Honcho’s quality flame grilled chicken and chips at the most affordable prices in town. Download the app, order your favourite food from Honcho’s to get the joy of food, delivered\n",banner:"seo/74b4651b-ff68-4e84-bad3-b8b679548849.png",logo:"seo/53c0464e-4884-4a0e-8845-336fed494f2a.png",isRetail:void 0},{slug:"mexi-go-go",name:"Mexi GO-GO",adminId:"1169",vertical:"restaurant",description:"Hungry for a taste of Mexico? Look no further! Mexi Go-Go is the tastiest, spiciest Mexican food around, delivered rápido to your door.\n\nNo traffic, no queues, no problemas! ¡Provecho!",banner:"seo/12cb22f1-9e5e-4611-9498-a9b2883729ee.png",logo:"seo/649437f5-bdd6-44a3-9ad9-058a1cd0da09.png",isRetail:void 0},{slug:"reel-sushi",name:"Reel Sushi",adminId:"1142",vertical:"restaurant",description:"In the mood for Sashimi , Nigiri or California roll? Get the sushi you’re craving delivered to your doorstep.Download the app to order from Sushi Reel\n",banner:"seo/e96a9b86-686c-4345-a3d4-f14141ce1904.jpg",logo:"seo/3229cad2-17be-4a81-9756-a2a175ba4cce.png",isRetail:void 0},{slug:"la-parada",name:"La Parada",adminId:"1035",vertical:"restaurant",description:"For a little something to nibble on or a long table of option, get spanish tapas delivered from one of Cape Towns most popular tapas bar and restaurant.  \n \n\n \n",banner:"seo/8a8f8231-d5c3-40ea-ad9c-2bffab049e0c.jpg",logo:"seo/6e0f7310-2477-48d2-a6ef-ee6317f0a401.png",isRetail:void 0},{slug:"afros-chicken-shop",name:"Afro's Chicken Shop",adminId:"178",vertical:"restaurant",description:"Chicken and tjips just the way you love them. Download the app, order your favourite food from Afro's Chicken shop to get the joy of food, delivered",banner:"seo/e5e18f34-3d28-4772-bde2-fc3c4fa1ba3d.jpg",logo:"seo/92e03f7e-b3b0-4c8b-bf4b-3acaefc91960.jpg",isRetail:void 0},{slug:"ocean-basket",name:"Ocean Basket",adminId:"5",vertical:"restaurant",description:"Fancy a seafood feast? How about some Ocean Basket delivered fast & hot. From their famous seafood platters to a classic fish & chips, we deliver it all. Find Ocean Basket in your hood on the app. ",banner:"seo/a6176739-4327-42d2-ac86-d00fffb305c0.jpg",logo:"seo/57121211-b1ef-4324-a167-53aac18ceeeb.png",isRetail:void 0},{slug:"ribs & burgers",name:void 0,adminId:void 0,vertical:void 0,description:void 0,banner:void 0,logo:void 0,isRetail:void 0},{slug:"brooklyn-brothers",name:"Brooklyn Brothers",adminId:"131",vertical:"restaurant",description:"Get a taste of New York on SA soil. Download the Mr D app and get smoky buffalo style chicken wings, the beefiest burgers and hand crafted shakes.",banner:"seo/6c0442c5-cd19-43ec-b208-9aa0f5e773f8.jpg",logo:"seo/01dda6c3-1312-44ad-acd7-c0653584eab4.jpg",isRetail:void 0},{slug:"toy-kingdom",name:"Toy Kingdom",adminId:"1882",vertical:"store",description:"Welcome to Toy Kingdom on Mr D,  your ultimate on-demand destination for all things toys and fun! Get your toys delivered to your home in minutes within Gauteng, KwaZulu-Natal and Western Cape (Cape Town and surrounding areas only). From timeless classics to the latest trending games, we have everything kids (and kids at heart) could ever dream of. Featuring trusted brands like LEGO, Barbie, and Hape, our wide selection guarantees endless smiles and joy for the whole family. With fast, reliable delivery straight to your door and high-quality toys for every age, playtime has never been easier. Shop now and unlock the magic of play with Toy Kingdom!",banner:"web-v2/cf0afbfe-93b5-4f05-8280-9aec6d047010.png",logo:"web-v2/9a5171e6-a969-46ab-8f3d-0e45c99eb78b.png",isRetail:true},{slug:"turn-n-tender",name:"Turn 'n Tender",adminId:"43",vertical:"restaurant",description:"Get your signature cuts from this award-winning steakhouse. Download the Mr D app and choose your grill, combo, burger or chicken schnitzel today.\n",banner:"seo/81287fa3-e62e-4bc9-9d4f-123d60eaf1d9.jpg",logo:"seo/96535cab-de50-40ae-84b8-9c49717c2d77.jpg",isRetail:void 0},{slug:"popeyes",name:"Popeyes",adminId:"1017",vertical:"restaurant",description:"Treat yourself to fried chicken that boasts a rich New Orleans heritage with authentic spicy & mild fried chicken, chicken strips, burgers, wraps and signature sides.Download the app, order your favourite food from Popeyes to get the joy of food, delivered",banner:"seo/2e87793f-1672-4230-baa7-d650232ca53f.png",logo:"seo/16030b98-2cd5-48d9-ac3f-0aeddc0b0b98.png",isRetail:void 0},{slug:"provenance-hermanus",name:"Provenance Hermanus",adminId:void 0,vertical:"store",description:"All our products use natural ingredients such as essential oils and are formulated and handmade locally in Hermanus, South Africa.",banner:"seo/68670260-fa2f-4333-997f-1599a4fec917.jpg",logo:"seo/ec256f7c-af65-4c42-b35f-ccc431fa6649.jpg",isRetail:void 0},{slug:"wimpy",name:"Wimpy",adminId:"16",vertical:"restaurant",description:"Get a road trip favourite without hitting the road, at all. Find a Wimpy near you on the app and get all your favourites delivered fast & hot. From Wimpy burgers to breakfasts you can get them at the tap of our app. ",banner:"seo/d57dea79-22b6-47c6-ae5b-c78da18044e1.jpg",logo:"seo/ad9dfcf9-8c6b-4253-89d4-ffaf705843ec.png",isRetail:true},{slug:"andiccio-24",name:"Andiccio 24",adminId:"1018",vertical:"restaurant",description:"From savoury to sweet, build the pizza of your dreams. Download the app, order your favourite food from Andiccio 24 to get the joy of food, delivered",banner:"seo/85eb9142-6687-4504-b4b6-395bd3387517.jpg",logo:"seo/5aa75fcc-7cf2-4022-bd45-115bb151027f.jpg",isRetail:void 0},{slug:"hungry-lion",name:"Hungry Lion",adminId:"1146",vertical:"restaurant",description:"Whether you feel like sharing or in the mood for meals for one, order Hungry Lion online at Mr D. Get your favourite meals at a tap of the app.   \n",banner:"web-v2/dd3dc055-a63e-4a31-860f-7b82e705de24.png",logo:"web-v2/39e739dc-e15b-483d-9520-0c0127d2c05f.png",isRetail:void 0},{slug:" famous-kalahari-biltong",name:"Famous Kalahari Biltong",adminId:"1068",vertical:"store",description:"Enjoy beef, ostrich & kudu from the Kalahari to the Karoo, delivered when you crave it most.\n\n",banner:"web-v2/5bb84834-ae03-444f-aa0f-f5d5ab197205.png",logo:"web-v2/8c26aa07-1e1d-40da-9f9c-0d1cee0ff1b2.png",isRetail:true},{slug:"bacinis",name:"Bacini's",adminId:"139",vertical:"restaurant",description:"Explore the rich Italian history of Bacini’s through their food. Their menu offers a range of pasta and pizza options to feast in. Download the app, order your favourite food from Bancini’s to get the food you feel like delivered fast & hot. ",banner:"seo/1d4e7db8-2722-413b-8735-58f5bd3c412e.png",logo:"seo/578feee4-6c7e-4fe4-8ecc-c1905d2b396b.png",isRetail:void 0},{slug:"pantry",name:"Pantry",adminId:1953,vertical:"restaurant",description:"Iconic artisanal selection that is perfect for a bougie brunch with your foodie friends or solo day-time dining in your own comfort. \n\n\n",banner:"web-v2/82dba010-47e7-43f6-858a-be3e21f7fb35.png",logo:"web-v2/ad4c4559-8e6a-460b-b3e9-cfce9eff6748.png",isRetail:void 0},{slug:"life-day-spa",name:"Life Day Spa",adminId:1940,vertical:"store",description:"The Life Day Spa Group is South Africa’s premier destination for luxury and wellness, bringing together 11 of the country’s most exclusive day spas. Each location offers a unique ambiance, thoughtfully designed to inspire beauty, relaxation, and well-being. With over five decades of dedication, this family-owned collection of refined spas is renowned for its unwavering commitment to excellence in service and professionalism. Shop Life Day Spa on Mr D and get luxurious treatment vouchers delivered in minutes. ",banner:"web-v2/39084c65-f9b6-4c94-b87a-feee0ac8dc71.png",logo:"web-v2/2072b315-748c-4807-9a2a-46c52741d56f.png",isRetail:void 0},{slug:"build-your-basket",name:"Build Your Basket",adminId:null,vertical:"store",description:"Build Your Basket is a creative gift basket brand from Cape Town. We pride ourselves in producing quality premium baskets at affordable prices.",banner:"seo/9ccf624a-8517-4c97-ace9-aedeb85800dd.jpg",logo:"seo/4970af2f-c347-47e9-ab5d-76a173734364.jpg",isRetail:void 0},{slug:"lupa",name:"Lupa",adminId:"50",vertical:"restaurant",description:"Expect Wood-fired excellence of wholesome, seasonal pizzas, pastas and seafood. Get the balance of authentic Italian ingredients delivered to your doorstep when you download the Mr D app.\n",banner:"seo/5ff897c7-f173-4bd9-bd8b-35562ad15d7d.jpg",logo:"seo/7cdf7d0c-0786-4b7c-8eda-7cbc4101ace5.jpg",isRetail:void 0},{slug:"old-town-italy",name:"Old Town Italy",adminId:"1115",vertical:"restaurant",description:"Pizza, pasta prosciutto or panini’s. All the P’s on Mr D. Download the app, order your Italian favourites from Old Town Italy to get the food delivered fast & hot.\n",banner:"seo/a9d79d48-1a15-4508-8d62-823487567cea.jpg",logo:"seo/405563fe-f389-4b73-a6f6-ce1a11973f33.jpg",isRetail:void 0},{slug:"krispy-kreme",name:"Krispy Kreme",adminId:"165",vertical:"restaurant",description:"When the sweet tooth is crying out for something tasty but the lazy legs don't feel like moving, we've got you covered. Get Krispy Kreme delivered fast & hot at the tap of an app. ",banner:"web-v2/5bb54484-7c94-4bd5-b2fb-aaae27547d02.png",logo:"seo/6cf56ed4-9c3a-41b5-88e5-dc7e9620a3c6.png",isRetail:void 0},{slug:"john-dorys",name:"John Dory's",adminId:"25",vertical:"restaurant",description:"Fancy a seafood feast? How about some John Dory's delivered fast & hot. From their famous seafood platters to a classic fish & chips, we deliver it all. Find John Dory's in your hood on the app. ",banner:"seo/c6a6de74-f1ae-453a-8d11-677bf40b41d3.jpg",logo:"seo/635d7489-b432-405b-846f-12319b4df5cb.png",isRetail:true},{slug:"the-pecking-order",name:"The Pecking Order",adminId:"1178",vertical:"restaurant",description:"At The Pecking Order we decided to focus on delivering one thing and one thing only: Clucken Good Chicken.\n\nSo we don’t have restaurants; we just have hard working chefs who put 100% effort into making the very best chicken they possibly can.",banner:"seo/ba6946c4-79ec-449d-b763-75765fef8b2d.png",logo:"seo/9f25b6a5-ec7a-4e92-9c2d-22d67048b6f2.png",isRetail:void 0},{slug:"schoon",name:"Schoon",adminId:"1130",vertical:"restaurant",description:"Enjoy breakfast, lunch, and bakery delivery from Schoon with Mr D. Download the app to order fast & hot delivery of the freshly baked goods from Schoon\n",banner:"seo/b92156b6-5cba-415e-9b83-0c46494f7fe1.jpg",logo:"seo/5458b60e-ace0-4aeb-9515-e60fcb69778f.jpg",isRetail:void 0},{slug:"checkers-liquorshop",name:"Checkers LiquorShop",adminId:null,vertical:"store",description:"Bring the party home. Get alcohol and drinks delivered from Checkers LiquorShop and enjoy in-store pricing. Look for a Checkers LiquorShop near you in the app now.",banner:"seo/4db721e5-c691-4dd1-849f-8fe368686127.jpg",logo:"seo/327bec43-cd29-4157-b903-9951f546132c.png",isRetail:void 0},{slug:"mochachos",name:" Mochachos",adminId:"22",vertical:"restaurant",descrip