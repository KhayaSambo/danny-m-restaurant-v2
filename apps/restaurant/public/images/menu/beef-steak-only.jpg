o/042688d0-6857-4a6f-a709-f7724c2b4762.jpg",isRetail:void 0},{slug:"party-city",name:"Party City",adminId:"1800",vertical:"store",description:"Party City on Mr D showcases quality party items available nationwide. Party City has the largest range of quality party products in South Africa sourced globally, including but not limited to balloons, dress up, accessories, banners, badges, gifting and more.\n\n\n",banner:"web-v2/54153334-c0dd-4ddc-9442-355f4bddf9a4.png",logo:"web-v2/1a146edd-9d27-4f69-8030-73be33d7d71f.png",isRetail:true},{slug:"kfc",name:"KFC",adminId:"38",vertical:"restaurant",description:"It’s no secret. The best delivery all your favourites from KFC, delivered fast & hot. No mater what you're hungry for from KFC, you can get it at the tap of an app. Find KFC near you on the app now and get Zinger wings, Colonel Burgers, Boxmasters, Streetwise meals and more delivered direct to you. ",banner:"web-v2/1f95665b-b7bc-499d-88a6-644072e5b7d7.png",logo:"web-v2/8ed0bd37-ca1b-4804-b6be-4fcdc63f3cda.png",isRetail:void 0},{slug:"mugg-and-bean",name:"Mugg and Bean",adminId:"14",vertical:"restaurant",description:"Whether you're on a coffee break or needing something more substantial you'll find something tasty on the Mugg & Bean menu. Get the joy of food, delivered",banner:"seo/c954a80f-b3f5-49cc-9960-c077f0f8ac3c.jpg",logo:"seo/13c633cf-59d2-43bd-83af-29214764dc7c.png",isRetail:void 0},{slug:"panarottis",name:"Panarottis",adminId:"17",vertical:"restaurant",description:"Get a pizza the action delivered fast & hot from Panarottis. From delicious pizzas to tasty pastas you can find it all at a Panarottis near you delivered at the tap of an app.",banner:"web-v2/b1827854-da1b-42a1-84a4-e6b4cc780a21.png",logo:"web-v2/7fcb6555-33d4-4b82-83b0-e45df77a4de9.png",isRetail:void 0},{slug:"chateau-gateaux",name:"Chateau Gateaux",adminId:"170",vertical:"restaurant",description:"Experience the taste of luxury with Chateau Gateaux, South Africa's premier patisserie. Our handcrafted cakes, pastries, and desserts are made with the finest ingredients, ensuring an unforgettable taste experience with every bite. Perfect for birthdays, anniversaries, corporate events, or just a sweet treat for yourself. Get it delivered in South Africa with Mr D. Satisfy your sweet tooth with Chateau Gateaux today!",banner:"seo/1c834867-b487-405d-8068-3d4a122b1eed.jpg",logo:"seo/0556b4c6-5e6e-43f6-8e9c-426b58532705.jpg",isRetail:true},{slug:"rocomamas",name:"RocoMamas",adminId:21,vertical:"restaurant",description:"\nBurgers are better on the couch and few people do burgers as well as RocoMama's. Enjoy their taste busting smash burgers from the comfort of the couch. Find RocoMama's near you and get the joy of food, delivered",banner:"web-v2/076e5b0b-e923-477a-9671-6bf19e976315.png",logo:"web-v2/a9ba3c2a-f039-4e24-9f01-a4f61403e9dc.png",isRetail:void 0},{slug:"steers",name:"Steers",adminId:"10",vertical:"restaurant",description:"It's flame grilled, fast & hot. Enjoy Steers famous flame grilled burgers at the tap of an app. Find a Steers near you, browse the menu, tap and enjoy. Whatever you feel like from Steers, we'll deliver it.    ",banner:"seo/c47a3194-67db-42b2-8c94-b07b9c99b629.jpg",logo:"seo/199ed4ca-1d56-4dae-b1ac-40bd999ec688.png",isRetail:void 0},{slug:"pedros",name:"Pedros",adminId:"1043",vertical:"restaurant",description:"Enjoy a flame-grilled chicken menu that comes with tasty twists and sweet surprises. Download the app, order your favourite food from Pedros to get the joy of food, delivered",banner:"seo/491227af-9e92-40b5-a841-23ad986ce3bb.png",logo:"seo/b9a856e3-4b75-489b-8b94-acef21e9eaa0.png",isRetail:void 0},{slug:"el-vivos",name:"El Vivo's",adminId:void 0,vertical:"restaurant",description:"Treat yourself to a delicious, healthy, affordable and fresh food for you and your family from El Vivos.Download the app, order your favourite food from El Vivos to get the joy of food, delivered",banner:"seo/139dbe37-2884-4f70-a195-db086ceb004f.png",logo:"seo/43eeaa98-2de0-4baf-869f-0571e6c1a629.png",isRetail:void 0},{slug:"takealotnow",name:"TakealotNow",adminId:"1798",vertical:"store",description:"Discover a world of convenience, and get 100s of your favourite takealot products delivered in minutes from takealotNOW, your one-stop online store in South Africa. Explore our wide range of products from top brands like Apple, Samsung, Asus, and Sony. Get the latest gadgets like Airpods, iPhones, and Bluetooth Speakers. Upgrade your home with our selection of Air Fryers, Smeg appliances, and DIY tools. Dive into a good read with our collection of Fiction and Non-Fiction Books. Keep your pets happy with our selection of Cat Food, Dog Food, and other Pet Supplies. Stay healthy with our Health and Body Care products from brands like Nivea and Gillette. Don't let loadshedding get you down, we've got you covered with our selection of UPS, Portable Power Stations, and Rechargeable Lights. Shop now at takealotNOW for all your Grocery, Household, Baby & Toddler needs and more. Delivered fast, until late, guaranteed",banner:"seo/1abcb173-5f9c-414d-8ad1-f12b930777bb.png",logo:"seo/6188964c-5f58-4e11-9c1c-bb633e0a855b.jpg",isRetail:true},{slug:"simply-asia",name:"Simply Asia",adminId:"8",vertical:"restaurant",description:"It's one of SA's favourite Asian restaurants. Find Simply Asia in your area and get the joy of food, delivered at the tap of our app. Enjoy all your Simply Asia favourites wherever you are. ",banner:"seo/93b9105e-0fc0-4763-a0d8-0cc9567fc631.jpg",logo:"seo/1a59c53b-3de9-4280-9bbc-871d7b60ce54.png",isRetail:void 0},{slug:"frozen-for-you",name:"Frozen For You",adminId:"1917",vertical:"store",description:"Frozen For You is now live on Mr D, bringing you gourmet-grade ready-made meals without the fuss. \nFrom creamy pastas and saucy curries to hearty stews and decadent desserts, every dish is frozen at its freshest and delivered in minutes*.",banner:"web-v2/dc024a56-3be0-4588-9b0c-bf78761cb6a5.png",logo:"web-v2/91f5d4d1-38e2-4184-83b8-8532236898a9.png",isRetail:true},{slug:"city-fuel",name:"City Fuel",adminId:"1895",vertical:"store",description:void 0,banner:void 0,logo:void 0,isRetail:true},{slug:"diy-now",name:"DIY Now",adminId:"1907",vertical:"store",description:void 0,banner:void 0,logo:void 0,isRetail:true},{slug:"just-wingz-group",name:"Just Wingz Group",adminId:"1305",vertical:"store",description:void 0,banner:void 0,logo:void 0,isRetail:true},{slug:"king-pie",name:"King Pie",adminId:"1237",vertical:"store",description:void 0,banner:void 0,logo:void 0,isRetail:true},{slug:"leetoile-effective-beauty-solutions",name:"Le'Etoile Effective Beauty Solutions",adminId:"1935",vertical:"store",description:void 0,banner:void 0,logo:void 0,isRetail:true},{slug:"liquor-city",name:"Liquor City",adminId:"90",vertical:"store",description:void 0,banner:void 0,logo:void 0,isRetail:true},{slug:"maskscara-group",name:"Maskscara Group",adminId:"1949",vertical:"store",description:void 0,banner:void 0,logo:void 0,isRetail:true},{slug:"over-the-counter",name:"Over The Counter",adminId:"1906",vertical:"store",description:void 0,banner:void 0,logo:void 0,isRetail:true},{slug:"pet-express",name:"Pet Express",adminId:"1863",vertical:"store",description:void 0,banner:void 0,logo:void 0,isRetail:true},{slug:"pet-topia-group",name:"Pet Topia Group",adminId:"1924",vertical:"store",description:void 0,banner:void 0,logo:void 0,isRetail:true},{slug:"rna-stationers-group",name:"RNA Stationers Group",adminId:"1926",vertical:"store",description:void 0,banner:void 0,logo:void 0,isRetail:true},{slug:"rush-hour-beauty",name:"Rush Hour Beauty",adminId:"1936",vertical:"store",description:void 0,banner:void 0,logo:void 0,isRetail:true},{slug:"vape-hero",name:"Vape Hero",adminId:"1919",vertical:"store",description:void 0,banner:void 0,logo:void 0,isRetail:true},{slug:"vape-king-group",name:"Vape King Group",adminId:"1956",vertical:"store",description:void 0,banner:void 0,logo:void 0,isRetail:true}],cuisines:[{slug:"hot-de